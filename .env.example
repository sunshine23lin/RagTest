# ==========================================
# LLM 提供商切换配置
# ==========================================

# 当前使用的 LLM 提供商，可选值: dashscope, openrouter, zhipu
LLM_PROVIDER=dashscope

# Embedding 提供商（默认跟随大模型，可单独设置）
# EMBEDDING_PROVIDER=dashscope

# ==========================================
# 阿里百炼配置 (dashscope)
# ==========================================
DASHSCOPE_API_KEY=sk-your-api-key-here

# ==========================================
# OpenRouter 配置 (openrouter)
# ==========================================
OPENROUTER_API_KEY=sk-or-your-api-key-here
OPENROUTER_MODEL=qwen/qwen-plus
OPENROUTER_FALLBACK_MODEL=qwen/qwen3.5-plus

# ==========================================
# 智普配置 (zhipu)
# ==========================================
ZHIPU_API_KEY=your-api-key-here
ZHIPU_LLM_MODEL=glm-4-plus
ZHIPU_FALLBACK_MODEL=glm-4
ZHIPU_EMBEDDING_MODEL=embedding-3
